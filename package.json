{
    "name": "server",
    "version": "1.0.0",
    "description": "Server for react.",
    "license": "ISC",
    "author": "burhanudin rabbani",
    "type": "module",
    "main": "index.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "tsx --watch src/index.ts",
        "start": "node dist/index.js",
        "build": "npm install && tsc && tsc-alias",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "dependencies": {
        "connect-mongo": "^6.0.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "mongoose": "^9.6.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/node": "^25.9.1",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "eslint": "^10.4.0",
        "eslint-plugin-perfectionist": "^5.9.0",
        "prettier": "^3.8.3",
        "tsc-alias": "^1.8.17",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0"
    },
    "imports": {
        "#*": "./src/*"
    }
}
